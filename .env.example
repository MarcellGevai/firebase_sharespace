# Firebase Web App config — másold le .env-be és töltsd ki.
# Firebase Console → Project Settings → General → Your apps → Web app → SDK setup and configuration → Config
# A VITE_ prefix kötelező, hogy a Vite a kliensoldali bundle-be tegye.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Nominatim (OpenStreetMap) geokódolás a térkép funkcióhoz.
# A Nominatim használati szabályzata szerint adj meg egy azonosító kapcsolatot.
VITE_NOMINATIM_USER_AGENT=Firebase-Sharespace/1.0 (kapcsolat: te@email.hu)
RESEND_API_KEY=""
