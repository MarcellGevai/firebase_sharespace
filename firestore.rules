rules_version = '2';

// Sharespace — Firestore security rules.
//
// The whole app runs client-side (static SPA), so these rules ARE the backend:
// they enforce everything the old SvelteKit `+server.ts` routes used to guard.
// The trickiest part — the 5-minute handover/return confirmation window — is
// enforced here with server time (`request.time`) compared against the
// `serverTimestamp()` the client wrote when it initiated the step. No Cloud
// Function required; a client cannot forge a later timestamp because the stored
// value must equal the initiating request's server time.

service cloud.firestore {
	match /databases/{database}/documents {

		function signedIn() {
			return request.auth != null;
		}
		function uid() {
			return request.auth.uid;
		}

		// ---- USERS ----
		// Profiles are readable by any signed-in user (needed to render chat
		// partners and profile pages). The rating aggregate fields can be bumped
		// by anyone (the review flow updates the reviewee's doc); every other
		// field is editable only by the owner.
		function ratingFields() {
			return ['trust_score', 'review_count', 'rating_sum'];
		}
		function onlyRatingChanged() {
			return request.resource.data.diff(resource.data).affectedKeys().hasOnly(ratingFields());
		}
		function noRatingChanged() {
			return !request.resource.data.diff(resource.data).affectedKeys().hasAny(ratingFields());
		}
		match /users/{userId} {
			// A username on the profile doc must be backed by a reservation this user
			// actually holds in /usernames. Without this the reservation would be
			// decoration: /users lets its owner write any non-rating field, so anyone
			// using the SDK directly could set a handle they never claimed - and it
			// is /users.username, not the reservation, that the app renders.
			function usernameIsClaimed() {
				return !('username' in request.resource.data)
					|| request.resource.data.username == ''
					|| (
						exists(/databases/$(database)/documents/usernames/$(request.resource.data.username.lower()))
						&& get(/databases/$(database)/documents/usernames/$(request.resource.data.username.lower())).data.uid == userId
					);
			}
			// request.resource.data is the whole post-write doc, not a diff, so an
			// unchanged username would otherwise re-run the lookup above on every
			// write - including a reviewer's rating update, which is not their doc.
			function usernameUnchanged() {
				return request.resource.data.get('username', '') == resource.data.get('username', '');
			}
			allow read: if signedIn();
			allow create: if signedIn() && userId == uid()
				&& request.resource.data.trust_score == 0
				&& request.resource.data.review_count == 0
				&& usernameIsClaimed();
			allow update: if signedIn() && (
				(userId == uid() && noRatingChanged() && (usernameUnchanged() || usernameIsClaimed()))
				|| onlyRatingChanged()
			);
			allow delete: if false;
		}

		// ---- USERNAMES ----
		// /usernames/{key} -> { uid }: the reservation that makes handles unique.
		// Firestore has no unique index, so THIS is the enforcement, not the client
		// transaction that writes it: `create` only applies when the doc does not
		// exist, and `update` is refused outright. Two people racing for the same
		// handle therefore cannot both win - the second write is an update, denied.
		//
		// Readable signed-out because the register form checks availability before
		// the account exists. That exposes nothing: usernames are displayed
		// publicly, and the uid they map to is already the public /profile/{uid}.
		match /usernames/{key} {
			allow read: if true;
			allow create: if signedIn() && request.resource.data.uid == uid()
				&& request.resource.data.keys().hasOnly(['uid']);
			allow update: if false;
			// Releasing your own handle, e.g. when changing it.
			allow delete: if signedIn() && resource.data.uid == uid();
		}

		// ---- LISTINGS ----
		// Public marketplace: anyone (even signed-out) can browse. Owner info is
		// denormalized onto the listing so browsing never needs to read /users,
		// keeping personal data (email, address, DOB) behind auth.
		match /listings/{id} {
			allow read: if true;
			allow create: if signedIn() && request.resource.data.owner_id == uid();
			allow update, delete: if signedIn() && resource.data.owner_id == uid();
		}

		// ---- WANTS (Igények) ----
		// Someone posting that they're looking for an item/service - public
		// marketplace, same posture as /listings.
		match /wants/{id} {
			allow read: if true;
			allow create: if signedIn() && request.resource.data.requester_id == uid();
			allow update, delete: if signedIn() && resource.data.requester_id == uid();
		}

		// ---- REQUESTS (deals + handover state machine) ----
		function isParty() {
			return uid() in resource.data.participants;
		}
		// Pre-acceptance ping-pong negotiation: whoever awaiting_response_from
		// points to may currently accept/reject/counter-offer. The .get() default
		// means requests written before this field existed keep today's
		// owner-responds-first behavior with no migration needed.
		function isAwaited() {
			return uid() == resource.data.get('awaiting_response_from', resource.data.owner_id);
		}
		function otherParty() {
			return uid() == resource.data.owner_id ? resource.data.requester_id : resource.data.owner_id;
		}
		// The terms under negotiation. Any change to these has to go back through
		// the other party, so every transition below either freezes them or hands
		// the turn over - never both-at-once.
		function termFields() {
			return ['start_date', 'end_date', 'price_offer'];
		}
		// Each helper describes exactly one legal transition of the state machine.
		// The affectedKeys() allowlists matter as much as the status checks: without
		// them "accept" could quietly carry a price edit along with it, which would
		// defeat the whole point of requiring acceptance.
		function acceptDeal() {
			return resource.data.status == 'PENDING'
				&& request.resource.data.status == 'ACCEPTED'
				&& isAwaited()
				&& request.resource.data.handover_status == resource.data.handover_status
				&& request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
		}
		function rejectDeal() {
			return resource.data.status == 'PENDING'
				&& request.resource.data.status == 'REJECTED'
				&& isAwaited()
				&& request.resource.data.handover_status == resource.data.handover_status
				&& request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
		}
		function modifyOffer() {
			return resource.data.status == 'PENDING'
				&& request.resource.data.status == 'PENDING'
				&& isAwaited()
				&& request.resource.data.awaiting_response_from == otherParty()
				&& request.resource.data.handover_status == resource.data.handover_status
				&& request.resource.data.diff(resource.data).affectedKeys()
					.hasOnly(termFields().concat(['status', 'awaiting_response_from']));
		}
		function initHandover() {
			return resource.data.status == 'ACCEPTED'
				&& resource.data.handover_status == 'PENDING'
				&& uid() == resource.data.owner_id
				&& request.resource.data.handover_status == 'HANDOVER_INITIATED'
				&& request.resource.data.handover_initiated_at == request.time;
		}
		function acceptHandover() {
			return resource.data.handover_status == 'HANDOVER_INITIATED'
				&& uid() == resource.data.requester_id
				&& request.resource.data.handover_status == 'HANDOVER_COMPLETED'
				&& request.resource.data.actual_rental_start == request.time
				&& request.time < resource.data.handover_initiated_at + duration.value(5, 'm');
		}
		function resetHandover() {
			return resource.data.handover_status == 'HANDOVER_INITIATED'
				&& request.resource.data.handover_status == 'PENDING';
		}
		// Revising an already-accepted deal drops it back into the ping-pong rather
		// than applying silently: status returns to PENDING and the other party owns
		// the next move, so nobody is bound by terms they never saw. Because
		// initHandover() requires status == 'ACCEPTED', this also makes the 5-minute
		// handover window unreachable until the revision is accepted.
		//
		// Deliberately no isAwaited() check: after acceptance awaiting_response_from
		// still points at whoever accepted, so requiring it would let only one of the
		// two parties revise. Either may - they just can't do it unilaterally.
		function reviseAcceptedDeal() {
			return resource.data.status == 'ACCEPTED'
				&& resource.data.handover_status == 'PENDING'
				&& request.resource.data.status == 'PENDING'
				&& request.resource.data.awaiting_response_from == otherParty()
				&& request.resource.data.handover_status == resource.data.handover_status
				&& request.resource.data.diff(resource.data).affectedKeys()
					.hasOnly(termFields().concat(['status', 'awaiting_response_from']));
		}
		function initReturn() {
			return resource.data.handover_status == 'HANDOVER_COMPLETED'
				&& uid() == resource.data.requester_id
				&& request.resource.data.handover_status == 'RETURN_INITIATED'
				&& request.resource.data.return_initiated_at == request.time;
		}
		function acceptReturn() {
			return resource.data.handover_status == 'RETURN_INITIATED'
				&& uid() == resource.data.owner_id
				&& request.resource.data.handover_status == 'RETURN_COMPLETED'
				&& request.resource.data.actual_rental_end == request.time
				&& request.time < resource.data.return_initiated_at + duration.value(5, 'm');
		}
		function resetReturn() {
			return resource.data.handover_status == 'RETURN_INITIATED'
				&& request.resource.data.handover_status == 'HANDOVER_COMPLETED';
		}
		function closeDeal() {
			return resource.data.handover_status == 'RETURN_COMPLETED'
				&& request.resource.data.handover_status == 'CLOSED';
		}
		match /requests/{id} {
			allow read: if signedIn() && isParty();
			// Either party may open a deal: a borrower requesting a listing, or a
			// lender making an offer on someone's want. Roles are by function, not by
			// who clicked - owner_id always provides the item and requester_id always
			// receives it, which is what initHandover()/acceptHandover() below rely on.
			// Whoever opens it hands the first turn to the other party; nobody gets to
			// open a deal that's already waiting on the person they opened it against.
			allow create: if signedIn()
				&& (uid() == request.resource.data.requester_id || uid() == request.resource.data.owner_id)
				&& request.resource.data.owner_id != request.resource.data.requester_id
				&& request.resource.data.status == 'PENDING'
				&& request.resource.data.handover_status == 'PENDING'
				&& request.resource.data.awaiting_response_from != uid()
				&& (request.resource.data.awaiting_response_from == request.resource.data.owner_id
					|| request.resource.data.awaiting_response_from == request.resource.data.requester_id)
				// participants drives read access (isParty), so it must be exactly the
				// two roles - not an arbitrary pair the creator picked.
				&& request.resource.data.participants.size() == 2
				&& request.resource.data.participants.hasAll([
					request.resource.data.owner_id,
					request.resource.data.requester_id
				]);
			allow update: if signedIn() && isParty()
				// Core identity fields can never be reassigned.
				&& request.resource.data.owner_id == resource.data.owner_id
				&& request.resource.data.requester_id == resource.data.requester_id
				&& request.resource.data.listing_id == resource.data.listing_id
				&& request.resource.data.participants == resource.data.participants
				&& (
					acceptDeal() || rejectDeal() || modifyOffer() || reviseAcceptedDeal()
					|| initHandover() || acceptHandover() || resetHandover() || initReturn()
					|| acceptReturn() || resetReturn() || closeDeal()
				);
			allow delete: if false;
		}

		// ---- MESSAGES ----
		function onlyIsReadChanged() {
			return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
		}
		match /messages/{id} {
			allow read: if signedIn() && uid() in resource.data.participants;
			allow create: if signedIn()
				&& request.resource.data.sender_id == uid()
				&& uid() in request.resource.data.participants
				&& request.resource.data.participants.size() == 2;
			// The recipient may flip is_read; nothing else is mutable.
			allow update: if signedIn() && uid() in resource.data.participants && onlyIsReadChanged();
			allow delete: if false;
		}

		// ---- NOTIFICATIONS ----
		// A user may create a notification addressed to another user (e.g. "new
		// request"/"new message"). It must record its author. Recipients read /
		// mark-read / delete only their own.
		match /notifications/{id} {
			allow read: if signedIn() && resource.data.user_id == uid();
			allow create: if signedIn() && request.resource.data.from == uid();
			allow update: if signedIn() && resource.data.user_id == uid()
				&& request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
			allow delete: if signedIn() && resource.data.user_id == uid();
		}

		// ---- REVIEWS ----
		// Doc id is `${requestId}_${reviewerId}`, so one review per reviewer per
		// deal is guaranteed at the rules layer (a second write hits `update`,
		// which is denied).
		match /reviews/{id} {
			allow read: if signedIn();
			allow create: if signedIn()
				&& request.resource.data.reviewer_id == uid()
				&& request.resource.data.rating is int
				&& request.resource.data.rating >= 1
				&& request.resource.data.rating <= 5;
			allow update, delete: if false;
		}
	}
}
